<Application
    x:Class="OpenReplay.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenReplay"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#00C16A" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#00DC82" />
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#007F45" />
            <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#00DC82" />
            <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="#052E16" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
